[core]
editor = "micro"
pager = delta --syntax-theme="Nord" --24-bit-color="always" --file-style="#84a0c6" --hunk-header-style="#84a0c6" --plus-style="syntax #45493e" --plus-emph-style="syntax #2C3025" --minus-style="normal #53343b" --minus-emph-style="normal #200108"
# Builtin FSMonitor (git ≥ 2.37) — uses FSEvents on macOS so prompt-time
# `git status` doesn't stat every tracked file. Pairs with untrackedCache.
fsmonitor = true
untrackedCache = true

[feature]
manyFiles = true
[user]
email = me@rajrajhans.com
name = Raj Rajhans

[pager]
diff = diffnav
show = diffnav

[pull]
rebase = false

[rebase]
autoStash = true

[init]
defaultBranch = main
[filter "lfs"]
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
